-- common.rdla has 24 lights, which falls under the 25-light
-- light acceleration threshold. This test adds an extra
-- 27 lights to surpass the 50-light limit to activate light
-- acceleration (the limit is 25 lights in scalar mode, 50 in vector)
--
-- The reason we do this is to ensure that per-lobe lightsets
-- behave identically within or outside of the light acceleration codepath

-- 13 extra lights to lightset1
lightpositions1 = {
    { -5.5, 4.5, -2.5 },
    { -4.0, 4.7,  0.0 },
    { -2.5, 4.9,  2.5 },
    { -1.0, 5.1, -2.5 },
    { -5.5, 6.0,  0.0 },
    { -4.0, 6.2,  2.5 },
    { -2.5, 6.4, -2.5 },
    { -1.0, 6.6,  0.0 },
    { -5.5, 7.5,  2.5 },
    { -4.0, 7.7, -2.5 },
    { -2.5, 7.9,  0.0 },
    { -1.0, 8.1,  2.5 },
    { -3.0, 8.5,  2.5 },
}

-- 14 extra lights to lightset2
lightpositions2 = {
    { 2.5, 4.7,  0.0 },
    { 4.0, 4.9,  2.5 },
    { 5.5, 5.1, -2.5 },
    { 1.0, 6.0,  0.0 },
    { 2.5, 6.2,  2.5 },
    { 4.0, 6.4, -2.5 },
    { 5.5, 6.6,  0.0 },
    { 1.0, 7.5,  2.5 },
    { 2.5, 7.7, -2.5 },
    { 4.0, 7.9,  0.0 },
    { 5.5, 7.9,  2.5 },
    { 2.5, 8.1, -2.5 },
    { 4.0, 8.3,  0.0 },
    { 5.5, 8.5,  2.5 },
}

local function addSphereLight(name, x, y, z, color, exposure)
    local light = SphereLight(name) {
        ["node_xform"] = translate(x, y, z),
        ["color"] = color,
        ["intensity"] = 20,
        ["exposure"] = exposure,
        ["normalized"] = false,
        ["radius"] = 0.45,
    }

    table.insert(allLights, light)
end

for i = 1, #lightpositions1 do
    local p = lightpositions1[i]
    addSphereLight("/Scene/lighting/lightset1/"..i.."add",
                   p[1], p[2], p[3],
                   Rgb(1.0, 0.45, 0.18),
                   0.2)
end

for i = 1, #lightpositions2 do
    local p = lightpositions2[i]
    addSphereLight("/Scene/lighting/lightset2/"..i.."add",
                   p[1], p[2], p[3],
                   Rgb(0.2, 0.7, 1.0),
                   0.35)
end

allLightSet = LightSet("all_lights")(allLights)
